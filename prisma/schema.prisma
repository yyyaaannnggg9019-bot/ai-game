generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  bio           String    @default("")
  games         Game[]
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Game {
  id            String    @id @default(cuid())
  title         String
  description   String
  thumbnail     String    @default("/placeholder-game.png")
  category      String
  tags          String
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  indexFile     String    @default("index.html")
  views         Int       @default(0)
  isPublished   Boolean   @default(true)
  likes         Like[]
  comments      Comment[]
  favorites     Favorite[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([authorId])
  @@index([isPublished])
}

model Comment {
  id            String    @id @default(cuid())
  content       String
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([gameId])
}

model Like {
  id            String    @id @default(cuid())
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([gameId, userId])
  @@index([gameId])
}

model Favorite {
  id            String    @id @default(cuid())
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([gameId, userId])
  @@index([gameId])
}
